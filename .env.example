# --- Database (Supabase Postgres, server-only) ---

# Pooled connection (PgBouncer transaction mode, port 6543).
# Used by Prisma's @prisma/adapter-pg at runtime.
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:6543/postgres?pgbouncer=true"

# Direct connection (port 5432).
# Used only by Prisma Migrate / introspection (datasource.directUrl).
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"

# --- Authentication (Auth.js v5, server-only) ---

# Session/JWT signing secret. Generate with `npx auth secret` or any sufficiently random string.
AUTH_SECRET="replace-with-a-random-secret"

# Optional: only required when the canonical deployment URL can't be auto-detected.
AUTH_URL="http://localhost:3000"

# Google OAuth Client (Web application), server-only.
# Authorized redirect URI for local dev: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-oauth-client-secret"

# --- Transactional email (Resend, server-only) ---

RESEND_API_KEY="replace-with-resend-api-key"
EMAIL_FROM="Agenda Pro <onboarding@example.com>"

# --- Storage (Supabase Storage, server-only) ---
# Used by lib/supabase/storage.ts to upload profile photos to the `avatars` bucket.
# NEVER expose these as NEXT_PUBLIC_* — the service role key bypasses RLS.
SUPABASE_URL="https://example.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
